<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.precious-metals-monitor.daily-research-run.sample</string>

    <key>Disabled</key>
    <true/>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>PLACEHOLDER_PROJECT_ROOT/scripts/daily_research_run.sh</string>
      <string>--skip-tests</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PLACEHOLDER_PROJECT_ROOT</string>

    <key>StandardOutPath</key>
    <string>PLACEHOLDER_PROJECT_ROOT/logs/local/launchd_daily_research_run.out</string>

    <key>StandardErrorPath</key>
    <string>PLACEHOLDER_PROJECT_ROOT/logs/failures/launchd_daily_research_run.err</string>

    <key>StartCalendarInterval</key>
    <array>
      <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>30</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>12</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>16</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>21</integer>
        <key>Minute</key>
        <integer>30</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>1</integer>
        <key>Minute</key>
        <integer>0</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>5</integer>
        <key>Minute</key>
        <integer>15</integer>
      </dict>
    </array>
  </dict>
</plist>
